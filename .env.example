# Copy to .env.local for `vercel dev`, or set in Vercel → Project → Settings → Environment Variables.
# Production will stay "Not configured" in Ops until these are set.

# Spotify Web API (Client Credentials) — live followers / popularity / top tracks
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Email list (first match wins)
# Option A — Kit / ConvertKit forms API
KIT_API_KEY=
KIT_FORM_ID=
# Aliases also accepted:
# CONVERTKIT_API_KEY=
# CONVERTKIT_FORM_ID=

# Option B — any webhook that accepts POST JSON { email, name?, source }
EMAIL_WEBHOOK_URL=
